{
  "name": "football-manager-game",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.13.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @football-manager/database db:generate",
    "db:migrate": "pnpm --filter @football-manager/database db:migrate",
    "db:deploy": "pnpm --filter @football-manager/database db:deploy",
    "db:studio": "pnpm --filter @football-manager/database db:studio",
    "db:format": "pnpm --filter @football-manager/database db:format",
    "db:validate": "pnpm --filter @football-manager/database db:validate",
    "clean": "rimraf node_modules .turbo dist",
    "docker:up": "docker compose --env-file .env -f infrastructure/docker-compose.yml up -d --build",
    "docker:down": "docker compose --env-file .env -f infrastructure/docker-compose.yml down",
    "docker:logs": "docker compose --env-file .env -f infrastructure/docker-compose.yml logs",
    "docker:ps": "docker compose --env-file .env -f infrastructure/docker-compose.yml ps"
  },
  "prisma": {
    "schema": "packages/database/prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "prisma": "^5.20.0",
    "rimraf": "^5.0.0",
    "turbo": "^1.10.0",
    "typescript": "^5.7.0"
  }
}
