generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum LoginContext {
  WEB
  ADMIN
}

enum ClubStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ClubBoardExpectation {
  AVOID_RELEGATION
  STABLE_SEASON
  TOP_HALF
  TITLE_CHALLENGE
  PROMOTION_PUSH
  DEVELOP_PLAYERS
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  passwordHash            String
  role                    UserRole                 @default(USER)
  isActive                Boolean                  @default(true)
  emailVerifiedAt         DateTime?
  lastLoginAt             DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  managerProfile          ManagerProfile?
  sessions                UserSession[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  loginAttempts           LoginAttempt[]
  auditLogsAsActor        AuditLog[]               @relation("AuditLogActor")
  auditLogsAsTarget       AuditLog[]               @relation("AuditLogTarget")
}

model ManagerProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  displayName String
  level       Int      @default(1)
  experience  Int      @default(0)
  locale      String   @default("tr-TR")
  timezone    String   @default("Europe/Istanbul")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  managedClub Club?    @relation("ClubCurrentManager")
}

model Club {
  id                      String               @id @default(uuid())
  currentManagerProfileId String?              @unique @map("ownerId")
  name                    String
  shortName               String
  slug                    String               @unique
  threeLetterCode         String?              @unique
  primaryColor            String               @default("#1F4E79")
  secondaryColor          String               @default("#FFFFFF")
  logoAssetKey            String?
  countryCode             String               @default("TR")
  city                    String               @default("Unknown")
  status                  ClubStatus           @default(ACTIVE)
  balance                 Decimal              @default(0) @db.Decimal(14, 2)
  transferBudget          Decimal              @default(0) @db.Decimal(14, 2)
  wageBudget              Decimal              @default(0) @db.Decimal(14, 2)
  currencyCode            String               @default("EUR")
  premiumCurrency         Int                  @default(0)
  reputation              Int                  @default(1)
  fanBase                 Int                  @default(1000)
  foundedYear             Int?
  foundedAt               DateTime             @default(now())
  managerAssignedAt       DateTime?
  stadiumName             String               @default("Main Stadium")
  stadiumCapacity         Int                  @default(10000)
  trainingFacilityLevel   Int                  @default(1)
  youthFacilityLevel      Int                  @default(1)
  currentLeagueId         String?
  divisionLevel           Int?
  boardExpectation        ClubBoardExpectation @default(STABLE_SEASON)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  currentManagerProfile   ManagerProfile?      @relation("ClubCurrentManager", fields: [currentManagerProfileId], references: [id], onDelete: SetNull)

  @@index([status, name, id])
  @@index([countryCode, status])
}

model UserSession {
  id              String         @id @default(uuid())
  userId          String
  tokenFamilyId   String
  deviceName      String?
  deviceType      String?
  browser         String?
  operatingSystem String?
  ipHash          String?
  countryCode     String?
  city            String?
  userAgentHash   String?
  lastSeenAt      DateTime
  expiresAt       DateTime
  revokedAt       DateTime?
  revokeReason    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens   RefreshToken[]

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model RefreshToken {
  id            String         @id @default(uuid())
  sessionId     String
  tokenHash     String         @unique
  parentTokenId String?
  expiresAt     DateTime
  usedAt        DateTime?
  revokedAt     DateTime?
  createdAt     DateTime       @default(now())
  session       UserSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  parentToken   RefreshToken?  @relation("RefreshTokenParent", fields: [parentTokenId], references: [id], onDelete: SetNull)
  childTokens   RefreshToken[] @relation("RefreshTokenParent")

  @@index([sessionId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id              String    @id @default(uuid())
  userId          String
  tokenHash       String    @unique
  expiresAt       DateTime
  usedAt          DateTime?
  revokedAt       DateTime?
  requestedIpHash String?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LoginAttempt {
  id            String       @id @default(uuid())
  userId        String?
  emailHash     String
  success       Boolean
  failureReason String?
  ipHash        String
  userAgentHash String?
  context       LoginContext
  createdAt     DateTime     @default(now())
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([emailHash, createdAt])
  @@index([ipHash, createdAt])
  @@index([userId, createdAt])
}

model AuditLog {
  id           String   @id @default(uuid())
  actorUserId  String?
  targetUserId String?
  action       String
  entityType   String?
  entityId     String?
  metadata     Json?
  ipHash       String?
  createdAt    DateTime @default(now())
  actor        User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  target       User?    @relation("AuditLogTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
}
